# Скопируй этот файл в .env и заполни значения.
# .env в git НЕ коммитится (см. .gitignore).

# --- Telegram-бот для доставки заказов (обязательно) ---
# Токен от @BotFather:
TELEGRAM_BOT_TOKEN=
# Твой chat_id (узнать: напиши боту, открой
# https://api.telegram.org/bot<ТОКЕН>/getUpdates и возьми chat.id):
TELEGRAM_CHAT_ID=

# --- hh.ru API (обязательно для источника hh) ---
# Осмысленный User-Agent, иначе hh отдаёт 403. Подставь свой контакт:
HH_USER_AGENT=FreelanceBot/1.0 (fr3izy9@gmail.com)

# --- Telethon (опционально, только для закрытых TG-каналов) ---
# Получить на https://my.telegram.org -> API development tools:
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
